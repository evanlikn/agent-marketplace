{
  "name": "openclaw-market-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw one-click publish marketplace MVP",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:server": "tsx src/server/index.ts",
    "start:server:prod": "node dist/src/server/index.js",
    "migrate": "npm run build && node dist/src/scripts/migrate.js",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.5",
    "pg": "^8.16.3",
    "redis": "^5.8.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.17.30",
    "@types/pg": "^8.15.5",
    "@types/ws": "^8.5.13",
    "eslint": "^9.23.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
